{
  "log": { "loglevel": "warning" },
  "dns": null,
  "inbounds": [
    {
      "tag": "wg-in",
      "listen": null,
      "port": WG_LISTEN_PORT,
      "protocol": "wireguard",
      "settings": {
        "secretKey": "WG_PRIVATE_KEY",
        "address": [
          "10.0.0.1/32"
        ],
        "peers": [
          {
            "publicKey": "WG_PEER_PUBLIC_KEY",
            "allowedIPs": [
              "10.0.0.3/32"
            ],
            "keepAlive": 0
          }
        ],
        "noKernelTun": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "VLESS_SERVER_ADDRESS",
            "port": VLESS_SERVER_PORT,
            "users": [
              {
                "id": "VLESS_SERVER_UUID",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "VLESS_FAKE_TLS_HOST",
          "publicKey": "VLESS_PUBLIC_KEY",
          "shortId": "VLESS_SHORT_ID",
          "fingerprint": "chrome"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "domain": [
          "VLESS_SERVER_ADDRESS"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "network": "udp",
        "port": 443,
        "outboundTag": "block"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "proxy"
      }
    ]
  }
}
