{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "tag": "vless-inbound",
      "listen": "VLESS_LISTEN_IP",
      "port": VLESS_PORT,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "VLESS_CLIENT_UUID",
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "VLESS_FAKE_DOMAIN:443",
          "xver": 0,
          "serverNames": ["VLESS_SERVER_DOMAIN", "VLESS_FAKE_DOMAIN"],
          "privateKey": "VLESS_PRIVATE_KEY",
          "shortIds": ["VLESS_SHORT_ID"]
        }
      },
      "xhttpSettings": {
        "path": "/api/v1/data",
        "mode": "auto",
        "extra": {
          "xPaddingBytes": "100-1000"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct-outbound",
      "protocol": "freedom"
    }
  ]
}
